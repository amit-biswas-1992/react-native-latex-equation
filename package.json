{
  "name": "react-native-latex-equation",
  "version": "0.2.1",
  "description": "Render inline LaTeX math ($...$ and $$...$$) inside React Native / Expo Text components, including mid-sentence equations mixed with regular text. Single-WebView KaTeX renderer with a fast path for plain-text strings.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "react-native",
    "expo",
    "latex",
    "katex",
    "math",
    "equations",
    "mathjax",
    "webview",
    "inline-math",
    "claude-code",
    "agent-skills"
  ],
  "author": "Amit Biswas <amit.biswas199202@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amit-biswas-1992/react-native-latex-equation.git"
  },
  "homepage": "https://github.com/amit-biswas-1992/react-native-latex-equation#readme",
  "bugs": {
    "url": "https://github.com/amit-biswas-1992/react-native-latex-equation/issues"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0",
    "react-native-webview": ">=11.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "react-native-webview": "^13.0.0",
    "typescript": "^5.0.0"
  }
}
